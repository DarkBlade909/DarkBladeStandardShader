        {
            "type": "Graphlit.CustomFunctionNode",
            "guid": "be870417-dfec-42ce-acae-9f571ceff1a7",
            "x": 499,
            "y": 4553,
            "connections": [
                {
                    "a": 2,
                    "b": 3,
                    "node": "9f48b555-4368-42ed-ab3f-c98e5256e3e3"
                }
            ],
            "precision": 0,
            "preview": 0,
            "previewDisabled": true,
            "data": "{\"_code\":\"// Converts a float3 (r, g, b) into a float3 (h, s, v)\\nvoid RGBToHSVNode(out float Hue, out float Saturation, out float Value, float3 rgb)\\n{\\n    float4 K = float4(0.0, -1.0 / 3.0, 2.0 / 3.0, -1.0);\\n    float4 p = lerp(float4(rgb.bg, K.w, K.z), float4(rgb.gb, K.x, K.y), step(rgb.b, rgb.g));\\n    float4 q = lerp(float4(p.xyw, rgb.r), float4(rgb.r, p.yzx), step(p.x, rgb.r));\\n\\n    float d = q.x - min(q.w, q.y);\\n    float e = 1.0e-10;\\n    float hsv = (abs(q.z + (q.w - q.y) / (6.0 * d + e)), d / (q.x + e), q.x);\\n}\",\"_file\":\"\",\"_shaderInclude\":{\"fileID\":10900000,\"guid\":\"091018cd556ae574f8293fb26424f856\",\"type\":3},\"_useFile\":true}"
        },
