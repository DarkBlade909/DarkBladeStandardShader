                    "node": "1a385caf-26c4-4281-91dd-afe3e4606280"
                },
                {
                    "a": 2,
                    "b": 2,
                    "node": "7bae5094-2286-47fb-8585-09f709024fa0"
                }
            ],
            "precision": 0,
            "preview": 0,
            "previewDisabled": true,
            "data": "{\"_code\":\"void RotateAboutAxis(float3 In, float3 Axis, float RotationDegrees, out float3 Out)\\r\\n{\\r\\n    Rotation = radians(Rotation);\\r\\n    float s = sin(Rotation);\\r\\n    float c = cos(Rotation);\\r\\n    float one_minus_c = 1.0 - c;\\r\\n\\r\\n    Axis = normalize(Axis);\\r\\n    float3x3 rot_mat = \\r\\n    {   one_minus_c * Axis.x * Axis.x + c, one_minus_c * Axis.x * Axis.y - Axis.z * s, one_minus_c * Axis.z * Axis.x + Axis.y * s,\\r\\n        one_minus_c * Axis.x * Axis.y + Axis.z * s, one_minus_c * Axis.y * Axis.y + c, one_minus_c * Axis.y * Axis.z - Axis.x * s,\\r\\n        one_minus_c * Axis.z * Axis.x - Axis.y * s, one_minus_c * Axis.y * Axis.z + Axis.x * s, one_minus_c * Axis.z * Axis.z + c\\r\\n    };\\r\\n    Out = mul(rot_mat,  In);\\r\\n}\",\"_file\":\"\",\"_shaderInclude\":{\"fileID\":10900000,\"guid\":\"366fd7180e6044b4a87b63a5f98b5267\",\"type\":3},\"_useFile\":true}"
        },
